# AI Providers (app works without both — falls back to seeded mock report)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database (optional — falls back to .local-data/ JSON store if not set)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Performance data (optional — falls back to heuristics if not set)
PAGESPEED_API_KEY=

# Storage for screenshots (optional)
SUPABASE_STORAGE_BUCKET=prompt-to-prod-screenshots

# Rate limiting (default: 5 scans per IP per hour)
SCAN_RATE_LIMIT_PER_HOUR=5

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
